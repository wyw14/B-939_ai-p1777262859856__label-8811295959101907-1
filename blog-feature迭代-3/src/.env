APP_NAME="Private Blog"
APP_ENV=local
APP_KEY=base64:UcmtCdUQyWn9YZWyhSiWHEMsR3iSBGKOSTKZ+uO62qY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
